  },
  "dependencies": {
    "axios": "^1.13.0",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pako": "^2.0.4",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  }
}
