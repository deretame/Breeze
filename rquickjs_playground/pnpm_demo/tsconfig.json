{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2020", "DOM"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "cases/**/*.ts", "types/**/*.d.ts", "*.mjs"]
}
